# Django Configuration Keys
SECRET_KEY=django-insecure-some-secure-development-key-2026
DEBUG=True

# Connection URI to Supabase PostgreSQL Database
# Format: postgres://[user]:[password]@[host]:[port]/[database]
# Example: postgres://postgres:mypassword@db.xxxxxx.supabase.co:5432/postgres
DATABASE_URL=postgres://postgres:[PASSWORD]@[HOST]:5432/postgres

# Celery Broker Configurations (Default to True for eager tasks testing without broker service)
CELERY_TASK_ALWAYS_EAGER=True
